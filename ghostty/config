# ============================================================================
# Ghostty Configuration
# ============================================================================
# Symlinked from ~/.slingshot/ghostty/config
# Location: ~/Library/Application Support/com.mitchellh.ghostty/config

# ----------------------------------------------------------------------------
# Font
# ----------------------------------------------------------------------------
font-family = JetBrains Mono
font-size = 14
font-feature = +liga

# ----------------------------------------------------------------------------
# Terminal
# ----------------------------------------------------------------------------
shell-integration = zsh
cursor-style = block
cursor-style-blink = true
confirm-close-surface = false

# ----------------------------------------------------------------------------
# Appearance (Opencode color scheme)
# ----------------------------------------------------------------------------
# Based on: https://github.com/anomalyco/opencode
background = #191515
foreground = #d4d4d4
cursor-color = #d4d4d4
selection-background = #d4d4d4
selection-foreground = #191515

# ANSI Colors (Opencode palette)
palette = 0=#000000    # Black
palette = 1=#e06c75    # Red
palette = 2=#98c379    # Green
palette = 3=#e5c07b    # Yellow
palette = 4=#56b6c2    # Blue
palette = 5=#c678dd    # Magenta
palette = 6=#56b6c2    # Cyan
palette = 7=#d4d4d4    # White
palette = 8=#808080    # Bright Black
palette = 9=#ff6c6b    # Bright Red
palette = 10=#b8db87   # Bright Green
palette = 11=#f5a742   # Bright Yellow
palette = 12=#61afef   # Bright Blue
palette = 13=#d55fde   # Bright Magenta
palette = 14=#5fd7ff   # Bright Cyan
palette = 15=#ffffff   # Bright White

window-padding-x = 4
window-padding-y = 4
window-decoration = auto
macos-titlebar-style = tabs
background-opacity = 1.0

# ----------------------------------------------------------------------------
# Scrollback
# ----------------------------------------------------------------------------
scrollback-limit = 50000

# ----------------------------------------------------------------------------
# Clipboard
# ----------------------------------------------------------------------------
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = true
clipboard-trim-trailing-spaces = true

# ----------------------------------------------------------------------------
# Keybindings
# ----------------------------------------------------------------------------
keybind = cmd+shift+k=reset
keybind = cmd+k=clear_screen

# ----------------------------------------------------------------------------
# Advanced
# ----------------------------------------------------------------------------
auto-update = check
auto-update-channel = stable
